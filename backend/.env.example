# Copiar a .env y ajustar valores.

# Debe usar el driver async (asyncpg). En Windows, si falla la conexión con "localhost",
# prueba 127.0.0.1 en el host (evita IPv6 ::1 cuando Postgres solo escucha en IPv4).
POSTGRES_URL=postgresql+asyncpg://usuario:clave@127.0.0.1:5432/nombre_base

# Opcional (por defecto hay valores razonables en app/core/config.py)
# POSTGRES_POOL_RECYCLE=280
# POSTGRES_POOL_TIMEOUT=60
# POSTGRES_CONNECT_TIMEOUT=60
# Si PostgreSQL está en LAN sin TLS y ves conexiones cortadas (WinError 10054 / asyncpg closed):
# POSTGRES_SSL_DISABLE=true

# MEDIA_PATH=...
