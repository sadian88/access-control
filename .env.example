# ── Base de datos ──
# Usa 'db' como host cuando ejecutes con Docker Compose.
# Si corres el backend fuera de Docker, cambia 'db' por 'localhost' o '127.0.0.1'.
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@db:5432/edge_guard

# ── Aplicación ──
SIMILARITY_THRESHOLD=0.55
DEBOUNCE_SECONDS=10

# Ruta de medios dentro del contenedor (no editar si usas Docker)
MEDIA_PATH=/app/media

# ── Autenticación JWT ──
JWT_SECRET=prism-super-secret-key-change-in-production-2026
JWT_EXPIRE_HOURS=8
JWT_ALGORITHM=HS256

# ── Frontend Admin (Clerk) ──
# Solo necesario si usas autenticación Clerk en el panel de administración.
# Se inyecta en build-time del contenedor admin.
VITE_CLERK_PUBLISHABLE_KEY=
