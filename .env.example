# Conexión a tu servidor PostgreSQL
# Formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_db
POSTGRES_URL=postgresql+asyncpg://postgres:Admin123!@localhost:5432/edge_guard

# Umbral de similitud vectorial (0.0 - 1.0)
# Más bajo = más estricto. Valor recomendado: 0.35 - 0.45
SIMILARITY_THRESHOLD=0.55

# Segundos de espera antes de volver a procesar la misma persona
DEBOUNCE_SECONDS=10

# Ruta donde se guardan las fotos capturadas (ruta local)
MEDIA_PATH=D:/Codigo/Edge_guard_Project/backend/media